# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# Virtual env
.venv/
venv/
env/
.uv-cache/

# Env
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# CodeBuddy / WorkBuddy 工作区数据
# 只保留项目级规则（.codebuddy/rules/），忽略聊天历史/缓存/个人 memory
.codebuddy/*
!.codebuddy/rules/
.workbuddy/

# OS
.DS_Store
Thumbs.db

# Test / Lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Data / Logs
# data/ 默认忽略；ra2 / aoe3 提取的精炼 JSON 需要入库
data/*
!data/ra2/
data/ra2/*
!data/ra2/*.json
!data/aoe3/
data/aoe3/*
!data/aoe3/*.json
logs/
*.log
*.db
*.sqlite
*.sqlite3

# NapCat volumes (dev)
napcat/data/

# OpenRA 参考源码（scripts/setup_openra_vendor 可重新克隆）
vendor/openra/
vendor/openra-ra2/

# Misc
*.bak
*.tmp

# 清洗产物（自动生成，不入库；可由 scripts/crawler/clean_crawled.py 重新产出）
scripts/crawler/raw/*.cleaned.json

# 游戏数据提取中间产物（从 Data.bar 解包的 XML，太大不入库；可由 aoe3_bar_extractor.py 重新产出）
scripts/crawler/_extracted/

# 名人梗图候选子目录（爬虫产出，人工挑选后只留根目录的代表图）
resources/checkin/celebrities/*/
