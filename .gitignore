# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# Virtual env
.venv/
venv/
env/
.uv-cache/

# Env
# 注：本项目为 Private 仓库，.env 被有意提交用于多地区同步配置。
# 仍忽略 .env.local 等本地覆盖层。
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# CodeBuddy / WorkBuddy 工作区数据
# 只保留项目级规则（.codebuddy/rules/），忽略聊天历史/缓存/个人 memory
.codebuddy/*
!.codebuddy/rules/
.workbuddy/

# OS
.DS_Store
Thumbs.db

# Test / Lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Data / Logs
data/
logs/
*.log
*.db
*.sqlite
*.sqlite3

# NapCat volumes (dev)
napcat/data/

# Misc
*.bak
*.tmp

# 清洗产物（自动生成，不入库；可由 scripts/crawler/clean_crawled.py 重新产出）
scripts/crawler/raw/*.cleaned.json
