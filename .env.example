# ============================================================
#  QQBotForFun · 环境变量样板
#  复制为 `.env` 并填入实际值。`.env` 不应提交到 git。
# ============================================================

# ---------- 应用基础 ----------
APP_ENV=dev
LOG_LEVEL=INFO

# NoneBot HTTP/WS 服务监听地址（NapCat 反连到这里）
HOST=0.0.0.0
PORT=8080

# 管理员 QQ 列表（逗号分隔，首位即 owner）
ADMIN_QQ=

# ---------- NoneBot 驱动 ----------
DRIVER=~fastapi+~websockets
COMMAND_START=["/",""]
COMMAND_SEP=[" "]

# ---------- OneBot (NapCat) ----------
# 机器人自身 QQ（仅用于日志显示，不强校验）
BOT_QQ=
# NapCat 反向连接 Bot 时使用的 access token
ONEBOT_ACCESS_TOKEN=change_me

# ---------- 数据库 ----------
# 开发（SQLite）
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
# 生产（PostgreSQL，示例）
# DATABASE_URL=postgresql+asyncpg://qqbot:qqbot_pass@postgres:5432/qqbot

# ---------- 缓存（可选）----------
# 留空则走内存；生产建议 Redis
REDIS_URL=
# REDIS_URL=redis://redis:6379/0

# ---------- LLM 配置 ----------
LLM_CONFIG_PATH=./config/llm.yaml

# 各供应商 Key（按需填写）
ZHIPU_API_KEY=
LONGCAT_API_KEY=
SILICONFLOW_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

# ---------- 海龟汤游戏配置 ----------
GAME_TURTLE_SOUP_MAX_QUESTIONS=50
GAME_TURTLE_SOUP_SESSION_TIMEOUT_MINUTES=60
GAME_TURTLE_SOUP_IDLE_TIMEOUT_MINUTES=15
GAME_TURTLE_SOUP_PREFER_LLM_GENERATION=false
GAME_TURTLE_SOUP_JUDGE_TIMEOUT_SECONDS=30
GAME_TURTLE_SOUP_CLAIM_TIMEOUT_SECONDS=45
GAME_TURTLE_SOUP_REWARD_ON_WIN=100
